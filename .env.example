# --- Admin-Login ---
# Passwort für den Admin-Bereich (/admin). Frei wählbar.
ADMIN_PASSWORD=dein-sicheres-passwort
# Zufälliger geheimer Wert für die Session-Signierung (frei wählbar, lang).
SESSION_SECRET=bitte-langen-zufallswert-eintragen

# --- Datenbank (Vercel Postgres) ---
# Wird automatisch von Vercel gesetzt, wenn du unter "Storage" eine
# Postgres-Datenbank mit dem Projekt verbindest. Lokal aus Vercel kopieren.
# POSTGRES_URL=

# --- Bild-Upload (Vercel Blob) ---
# Wird automatisch gesetzt, wenn du unter "Storage" einen Blob-Store verbindest.
# Ohne diesen Token können Bilder nur per URL eingefügt werden.
# BLOB_READ_WRITE_TOKEN=
